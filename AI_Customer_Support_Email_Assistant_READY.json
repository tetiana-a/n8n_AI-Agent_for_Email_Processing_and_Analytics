            "category": "={{ $json.category }}",
            "sentiment": "={{ $json.sentiment }}",
            "requires_human": "={{ $json.requires_human }}",
            "reason": "={{ $json.reason }}"
          }
        },
        "options": {}
      },
      "credentials": {
        "googleSheetsOAuth2Api": {
          "id": "REPLACE_WITH_GOOGLE_SHEETS_CREDENTIAL_ID",
          "name": "Google Sheets account"
        }
      }
    },
    {
      "id": "5ea418c4-d02b-4245-bc1f-9208bfef53fc",
      "name": "README - Google Sheets structure",
      "type": "n8n-nodes-base.stickyNote",
      "typeVersion": 1,
      "position": [
        20,
        -520
      ],
      "parameters": {
        "color": 5,
        "width": 680,
        "height": 320,
        "content": "# Google Sheets setup\n\nCreate two tabs:\n\n## FAQ\nColumns:\ncategory | question | approved_answer | template_key\n\nExample:\nBilling | How can I get invoice? | Thank you for your message. We can send the invoice... | billing_invoice\n\n## Logs\nColumns:\nprocessed_at | email_id | from | subject | priority | category | sentiment | requires_human | reason\n\nImportant production rule: AI only drafts responses from approved FAQ/template data. It does not send directly."
      }
    }
